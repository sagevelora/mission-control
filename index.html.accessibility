                }
            });
            
            // Search in agents
            state.agents.forEach(agent => {
                if (agent.name.toLowerCase().includes(searchTerm)) {
                    searchResults.push({ type: 'agent', id: agent.id, content: agent.name });
                }
            });
            
            // Search in notes
            if (state.notes.toLowerCase().includes(searchTerm)) {
                searchResults.push({ type: 'notes', content: 'Notes contain search term' });
            }
            
            // Search in activity log
            state.activityLog.forEach((item, index) => {
                if (item.message.toLowerCase().includes(searchTerm)) {
                    searchResults.push({ type: 'activity', index: index, content: item.message });
                }
            });
            
            // Highlight results in current tab
            highlightSearchResults(searchTerm);
            
            // Show notification with result count
            if (searchResults.length > 0) {
                showNotification(`Found ${searchResults.length} result${searchResults.length === 1 ? '' : 's'} for "${searchTerm}"`, 'info');
            } else {
                showNotification(`No results found for "${searchTerm}"`, 'warning');
            }
