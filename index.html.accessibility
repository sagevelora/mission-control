        // Fetch data from VPS endpoints with proper error handling
        async function fetchData() {
            // Don't poll if tab is not visible
            if (!state.isVisible) {
                return;
            }

            try {
                // Fetch all endpoints in parallel
                const endpoints = [
                    fetch(`${CONFIG.VPS_URL}/api/metrics`),
                    fetch(`${CONFIG.VPS_URL}/api/projects`),
                    fetch(`${CONFIG.VPS_URL}/api/agents`),
                    fetch(`${CONFIG.VPS_URL}/api/activity`)
                ];

                const responses = await Promise.all(endpoints);

                // Check if all responses are ok
                if (responses.every(res => res.ok)) {
                    const [metricsRes, projectsRes, agentsRes, activityRes] = responses;
                    const [metrics, projects, agents, activity] = await Promise.all([
                        metricsRes.json(),
                        projectsRes.json(),
                        agentsRes.json(),
                        activityRes.json()
                    ]);

                    // Update state
                    state.metrics = metrics;
                    state.projects = projects;
                    state.agents = agents;
                    state.activityLog = activity.slice(0, CONFIG.MAX_ACTIVITY_ITEMS);
                    
                    state.connectionStatus = 'connected';
                    updateConnectionStatus();
                    
                    // Render all tabs
                    renderMetrics();
                    renderProjects();
                    renderAgents();
                    renderActivityFeed();
                    renderInsights();
                    
                    // Check for alerts and notifications
                    checkAlerts();
                } else {
                    throw new Error('One or more API endpoints failed');
                }
            } catch (error) {
                console.error('Error fetching data:', error);
                state.connectionStatus = 'disconnected';
                updateConnectionStatus();
                
                // Only show error in dashboard tab to avoid spamming
                if (document.querySelector('.tab-content.active').id === 'dashboardTab') {
                    showErrorMessage('No connection to OpenClaw VPS');
                }
            }
        }

